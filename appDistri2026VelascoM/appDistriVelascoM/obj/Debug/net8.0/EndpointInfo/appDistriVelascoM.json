  "components": {
    "schemas": {
      "ClienteDTOs": {
        "required": [
          "apellidoCliente",
          "cedulaCliente",
          "emailCliente",
          "fechaNacimientoCliente",
          "nombreCliente",
          "telefonoCliente"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "estado": {
            "type": "boolean"
          },
          "nombreCliente": {
            "minLength": 1,
            "type": "string"
          },
          "apellidoCliente": {
            "minLength": 1,
            "type": "string"
          },
          "emailCliente": {
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9._%+-]+@(gmail|outlook|hotmail|yahoo)\\.com$",
            "type": "string",
            "format": "email"
          },
          "cedulaCliente": {
            "maxLength": 13,
            "minLength": 10,
            "pattern": "^\\d+$",
            "type": "string"
          },
          "telefonoCliente": {
            "maxLength": 10,
            "minLength": 6,
            "pattern": "^\\d+$",
            "type": "string"
          },
          "fechaNacimientoCliente": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "DireccionDTOs": {
        "required": [
          "calleDireccion",
          "ciudadDireccion",
          "codigoPostalDireccion",
          "idCliente",
          "provinciaDireccion"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "estado": {
            "type": "boolean"
          },
          "idCliente": {
            "type": "integer",
            "format": "int32"
          },
          "provinciaDireccion": {
            "minLength": 1,
            "type": "string"
          },
          "ciudadDireccion": {
            "minLength": 1,
            "type": "string"
          },
          "calleDireccion": {
            "minLength": 1,
            "type": "string"
          },
          "codigoPostalDireccion": {
            "minLength": 1,
            "pattern": "^\\d+$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "type": "integer",
            "format": "int32"
          },
          "temperatureF": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "summary": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
